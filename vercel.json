{
"headers": [
    {
    "source": "/panoramas/(.*)",
    "headers": [
        {
        "key": "Cache-Control",
        "value": "public, max-age=31536000, immutable"
        }
    ]
    },
    {
    "source": "/images/(.*)",
    "headers": [
        {
        "key": "Cache-Control",
        "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
    ]
    },
    {
    "source": "/_next/static/(.*)",
    "headers": [
        {
        "key": "Cache-Control",
        "value": "public, max-age=31536000, immutable"
        }
    ]
    }
]
}
